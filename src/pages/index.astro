---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>Andrew Coco | Web Strategy, SEO & AI Discovery Leader</title>
    <meta name="description" content="Andrew Coco is a growth and web strategy leader at Peacock / NBCUniversal focused on AI discovery, AEO, GEO, SEO, experimentation, CRO, and subscription growth." />
    <link rel="canonical" href="https://www.andrewco.co/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.andrewco.co/" />
    <meta property="og:title" content="Andrew Coco | Web Strategy, SEO & AI Discovery Leader" />
    <meta property="og:description" content="Growth and web strategy leader at Peacock / NBCUniversal. Focused on AI discovery, AEO, GEO, SEO, CRO, and subscription growth." />
    <meta property="og:image" content="https://www.andrewco.co/andrew_coco.png" />
    <meta property="og:image:alt" content="Andrew Coco, Senior Director of Web Strategy at Peacock and NBCUniversal" />
    <meta property="og:site_name" content="Andrew Coco" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Andrew Coco | Web Strategy, SEO & AI Discovery Leader" />
    <meta name="twitter:description" content="Growth and web strategy leader at Peacock / NBCUniversal. Focused on AI discovery, AEO, GEO, SEO, CRO, and subscription growth." />
    <meta name="twitter:image" content="https://www.andrewco.co/andrew_coco.png" />

    <!-- Person Schema JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Andrew Coco",
      "url": "https://www.andrewco.co",
      "image": "https://www.andrewco.co/andrew_coco.png",
      "jobTitle": "Senior Director of Web Strategy",
      "worksFor": {
        "@type": "Organization",
        "name": "Peacock / NBCUniversal"
      },
      "alumniOf": {
        "@type": "EducationalOrganization",
        "name": "San Diego State University"
      },
      "award": "Sports Emmy Award, 46th Sports Emmys 2025",
      "sameAs": [
        "https://www.linkedin.com/in/andrewcoco/"
      ],
      "knowsAbout": [
        "Web Strategy",
        "SEO",
        "Answer Engine Optimization",
        "Generative Engine Optimization",
        "AI Search Strategy",
        "Conversion Rate Optimization",
        "Experimentation",
        "Subscription Growth",
        "Media Digital Strategy"
      ]
    }
    </script>
  </head>

  <body>

    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="wordmark">Andrew Coco</a>
        <nav aria-label="Primary navigation">
          <a href="https://www.linkedin.com/in/andrewcoco/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </nav>
      </div>
    </header>

    <main id="main-content">

      <!-- HERO -->
      <section class="hero" aria-labelledby="hero-heading">
        <div class="container hero-inner">
          <div class="hero-text">
            <p class="hero-eyebrow">Senior Director of Web Strategy · Peacock / NBCUniversal</p>
            <h1 id="hero-heading">Andrew Coco</h1>
            <p class="hero-tagline">Building growth systems for the next era of discovery.</p>
            <p class="hero-sub">I lead web strategy, SEO, AI discovery, and experimentation programs that grow audiences and drive subscription growth at scale.</p>
          </div>
          <div class="hero-photo">
            <img
              src="/andrew_coco.png"
              alt="Andrew Coco, Senior Director of Web Strategy at Peacock and NBCUniversal"
              width="320"
              height="320"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      </section>

      <!-- ABOUT -->
      <section class="section about" aria-labelledby="about-heading">
        <div class="container">
          <h2 id="about-heading" class="section-label">About</h2>
          <div class="about-body">
            <p>I'm a growth and web strategy leader who thinks about owned web as a competitive acquisition surface, not just a destination. My work connects search visibility, AI-driven discovery, experimentation, and conversion into a coherent system for growing subscription audiences at scale.</p>
            <p>At Peacock and NBCUniversal, I lead strategy across SEO, Answer Engine Optimization (AEO), Generative Engine Optimization (GEO), acquisition landing experiences, and CRO. I also oversee a cross-organization AI Search committee focused on growing NBCUniversal's visibility across AI-powered discovery surfaces. My focus is on durable, owned growth rather than purely paid channels.</p>
            <p>My background spans technical SEO, editorial ecosystems, experimentation frameworks, and product-minded web strategy across media, e-commerce, and subscription businesses. I think of myself as a strategist who understands search deeply, not the other way around.</p>
          </div>
        </div>
      </section>

      <!-- FOCUS AREAS -->
      <section class="section focus" aria-labelledby="focus-heading">
        <div class="container">
          <h2 id="focus-heading" class="section-label">Focus Areas</h2>
          <ul class="focus-grid" role="list">
            <li class="focus-item">
              <h3>Web Strategy</h3>
              <p>Owned web as a growth and acquisition surface. Architecture, experience, and strategy aligned to business outcomes rather than vanity metrics.</p>
            </li>
            <li class="focus-item">
              <h3>SEO, AEO & GEO</h3>
              <p>Organic search, Answer Engine Optimization, and Generative Engine Optimization. Building content and technical systems that perform across traditional search and AI-powered discovery surfaces.</p>
            </li>
            <li class="focus-item">
              <h3>Experimentation & CRO</h3>
              <p>A/B testing and conversion systems that compound over time. Treating experimentation as an operating discipline, not a one-off tactic.</p>
            </li>
            <li class="focus-item">
              <h3>Subscription Growth</h3>
              <p>Acquisition funnel strategy for media and subscription products. From discovery to trial to loyal subscriber, with owned web doing real work at every stage.</p>
            </li>
            <li class="focus-item">
              <h3>Acquisition Surfaces</h3>
              <p>Designing and optimizing the landing experiences, editorial surfaces, and owned channels that convert attention into audience.</p>
            </li>
            <li class="focus-item">
              <h3>AI Search Strategy</h3>
              <p>Helping media organizations understand and adapt to how AI assistants, generative search, and new discovery interfaces are reshaping audience acquisition.</p>
            </li>
          </ul>
        </div>
      </section>

      <!-- WHAT I'M THINKING ABOUT -->
      <section class="section thinking" aria-labelledby="thinking-heading">
        <div class="container">
          <h2 id="thinking-heading" class="section-label">What I'm Thinking About</h2>
          <p class="thinking-intro">A few problems I keep coming back to.</p>
          <ul class="thinking-list" role="list">
            <li>
              <strong>AI search measurement is still fundamentally broken.</strong> Most teams are reporting on AI visibility using proxies that don't reflect how answers are actually generated or how users behave after them. Until measurement catches up, strategy will keep lagging.
            </li>
            <li>
              <strong>Search interfaces are disintermediating traffic to the open web</strong>, and the implications for owned web strategy are bigger than most organizations are treating them. When the answer surface becomes the destination, what is a website actually for?
            </li>
          </ul>
        </div>
      </section>

      <!-- BACKGROUND -->
      <section class="section background" aria-labelledby="background-heading">
        <div class="container">
          <h2 id="background-heading" class="section-label">Background</h2>

          <div class="background-body">

            <div class="bg-block">
              <h3 class="bg-block-title">Experience</h3>
              <ol class="career-list" role="list">
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">Sr. Director, Web Strategy</span>
                    <span class="career-company">NBCUniversal / Peacock</span>
                  </div>
                  <span class="career-date">2025 — Present</span>
                </li>
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">Director, Growth Product SEO</span>
                    <span class="career-company">NBCUniversal / Peacock & NBC Sports</span>
                  </div>
                  <span class="career-date">2021 — 2025</span>
                </li>
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">Customer Engagement SEO Manager</span>
                    <span class="career-company">The Walt Disney Company</span>
                  </div>
                  <span class="career-date">2020 — 2021</span>
                </li>
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">E-Commerce SEO Manager</span>
                    <span class="career-company">GUESS?</span>
                  </div>
                  <span class="career-date">2018 — 2020</span>
                </li>
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">Sr. SEO Specialist</span>
                    <span class="career-company">HZDG</span>
                  </div>
                  <span class="career-date">2017 — 2018</span>
                </li>
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">Search Marketing Analyst</span>
                    <span class="career-company">Digitas</span>
                  </div>
                  <span class="career-date">2016 — 2017</span>
                </li>
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">SEO Coordinator</span>
                    <span class="career-company">Geary LSF</span>
                  </div>
                  <span class="career-date">2015 — 2016</span>
                </li>
              </ol>
            </div>

            <div class="bg-block">
              <h3 class="bg-block-title">Education</h3>
              <ol class="career-list" role="list">
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">B.S. Business Administration, Marketing</span>
                    <span class="career-company">San Diego State University</span>
                  </div>
                  <span class="career-date">2014</span>
                </li>
              </ol>
            </div>

            <div class="bg-block">
              <h3 class="bg-block-title">Highlights</h3>
              <ol class="career-list" role="list">
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">Sports Emmy Award</span>
                    <span class="career-company">Outstanding Interactive Experience, 2024 Paris Olympics — NBC / Peacock</span>
                  </div>
                  <span class="career-date">2025</span>
                </li>
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">Conference Organizer & Speaker</span>
                    <span class="career-company">Comcast NBCUniversal Internal SEO Summit, 200+ attendees</span>
                  </div>
                  <span class="career-date">2023</span>
                </li>
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">Conference Speaker</span>
                    <span class="career-company">SEO Day, presented to 50K and 129K attendees across two events</span>
                  </div>
                  <span class="career-date">2021 — 2022</span>
                </li>
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">Featured Contributor</span>
                    <span class="career-company">Search Engine Journal, Rankz.IO, JBH.co.uk, SEO for Journalism</span>
                  </div>
                  <span class="career-date">2020 — 2024</span>
                </li>
                <li class="career-item">
                  <div class="career-meta">
                    <span class="career-role">53 Best SEO Experts of 2020</span>
                    <span class="career-company">Northstar Inbound Agency</span>
                  </div>
                  <span class="career-date">2020</span>
                </li>
              </ol>
            </div>

          </div>
        </div>
      </section>

      <!-- CONTACT -->
      <section class="section contact" aria-labelledby="contact-heading">
        <div class="container">
          <h2 id="contact-heading" class="section-label">Get in Touch</h2>
          <p class="contact-intro">Open to conversations about web strategy, AI discovery, media growth, and the future of owned web.</p>
          <div class="contact-links">
            <a href="https://www.linkedin.com/in/andrewcoco/" target="_blank" rel="noopener noreferrer" class="contact-btn">Connect on LinkedIn</a>
          </div>
        </div>
      </section>

    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-name">Andrew Coco</p>
        <p class="footer-copy">&copy; 2025 · andrewco.co</p>
      </div>
    </footer>

  </body>
</html>